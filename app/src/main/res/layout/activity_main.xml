<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="[schemas.android.com](http://schemas.android.com/apk/res/android)"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#ECEFF1">

    <TextView
        android:text="🛡️ ShieldIndia"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:text="Scam Detection &amp; Protection"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"/>

    <Button
        android:id="@+id/btnScanSms"
        android:text="🔍  Scan Last 50 SMS"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#1A237E"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvScanResult"
        android:text="Tap the button to scan your recent messages"
        android:textSize="15sp"
        android:textColor="#333333"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:text="Detected Threats"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#B71C1C"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <ListView
        android:id="@+id/lvScamLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:dividerHeight="1dp"/>

</LinearLayout>
